---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../lib/posts';
import { getDictionary, getLocalizedPath, type Locale } from '../lib/site';

interface Props {
  post: CollectionEntry<'posts'>;
  locale: Locale;
}

const { post, locale } = Astro.props as Props;
const copy = getDictionary(locale);
const href = getLocalizedPath(locale, `blog/${post.data.pathSlug}`);
---

<article class="post-card" data-accent={post.data.accent}>
  <div class="post-card__topline">
    <span class="pill">{post.data.category}</span>
    <time datetime={post.data.publishedAt.toISOString()}>{formatDate(post.data.publishedAt, locale)}</time>
  </div>

  <div class="post-card__body">
    <h3>{post.data.title}</h3>
    <p>{post.data.excerpt}</p>
  </div>

  <div class="post-card__footer">
    <div class="tag-row">
      {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>
    <a class="text-link" href={href}>{copy.nav.blog}</a>
  </div>
</article>