---
import LocaleSwitch from './LocaleSwitch.astro';
import ThemeToggle from './ThemeToggle.astro';
import { NAV_ITEMS, PROFILE, getDictionary, getLocalizedPath, type Locale, type NavKey } from '../lib/site';

interface Props {
  locale: Locale;
  currentNav: NavKey;
  paths: Record<Locale, string>;
}

const { locale, currentNav, paths } = Astro.props as Props;
const copy = getDictionary(locale);
const brandPath = getLocalizedPath(locale);
const searchLabel = locale === 'zh' ? '搜索' : 'Search';
---

<header class="site-header">
  <a class="brand" href={brandPath}>
    <span class="brand__mark">YL</span>
    <span class="brand__text">
      <strong>{copy.branding.title}</strong>
      <small>{copy.branding.subtitle}</small>
    </span>
  </a>

  <nav class="site-nav" aria-label="Primary">
    {NAV_ITEMS.map((item) => (
      <a class:list={['site-nav__item', currentNav === item && 'is-active']} href={getLocalizedPath(locale, item === 'home' ? '' : item)}>
        {copy.nav[item]}
      </a>
    ))}
  </nav>

  <div class="site-header__actions">
    <div class="site-header__identity">
      <span>{PROFILE.name[locale]}</span>
    </div>

    <div class="site-header__links">
      <a class="site-header__utility" href={getLocalizedPath(locale, 'search')}>{searchLabel}</a>
      <a class="site-header__utility" href={getLocalizedPath(locale, 'studio')}>{copy.nav.studio}</a>
    </div>

    <LocaleSwitch locale={locale} paths={paths} />
    <ThemeToggle locale={locale} />
  </div>
</header>
