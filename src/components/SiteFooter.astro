---
import { PROFILE, SITE, getDictionary, type Locale } from '../lib/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props as Props;
const copy = getDictionary(locale);
---

<footer class="site-footer">
  <div class="site-footer__copy">
    <p class="site-footer__title">{copy.footer.title}</p>
    <p class="site-footer__description">{copy.footer.description}</p>
  </div>

  <div class="site-footer__meta">
    <span>{PROFILE.name[locale]}</span>
    <a href={SITE.profileUrl} target="_blank" rel="noreferrer">GitHub</a>
    <a href={SITE.commentsRepositoryUrl} target="_blank" rel="noreferrer">Comments</a>
    <a href={`mailto:${SITE.email}`}>Email</a>
  </div>
</footer>