---
import { SITE, getDictionary, type Locale } from '../lib/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props as Props;
const copy = getDictionary(locale);
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div>
    <p class="site-footer__title">{copy.footer.title}</p>
    <p class="site-footer__description">{copy.footer.description}</p>
  </div>

  <div class="site-footer__links">
    <a href={SITE.profileUrl} target="_blank" rel="noreferrer">GitHub</a>
    <a href={SITE.repositoryUrl} target="_blank" rel="noreferrer">Repository</a>
    <span>{year}</span>
  </div>
</footer>
