---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props as Props;
---

<section class="page-intro panel">
  <p class="eyebrow">{eyebrow}</p>
  <h1>{title}</h1>
  <p class="page-intro__description">{description}</p>
  <slot />
</section>