---
import { getDictionary, type Locale } from '../lib/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props as Props;
const copy = getDictionary(locale);
---

<button class="theme-toggle" type="button" data-theme-toggle data-locale={locale} aria-label={copy.nav.theme}>
  <span class="theme-toggle__track" aria-hidden="true">
    <span class="theme-toggle__indicator"></span>
  </span>
  <span class="theme-toggle__label" data-theme-label></span>
</button>

<script is:inline>
  const themeStorageKey = 'ylb-theme';
  const themeCopy = {
    zh: { light: '浅色', dark: '深色', next: { light: '切换到浅色', dark: '切换到深色' } },
    en: { light: 'Light', dark: 'Dark', next: { light: 'Switch to light', dark: 'Switch to dark' } }
  };

  const getTheme = () => document.documentElement.dataset.theme === 'light' ? 'light' : 'dark';

  const applyTheme = (theme) => {
    document.documentElement.dataset.theme = theme;
    document.documentElement.style.colorScheme = theme;
    localStorage.setItem(themeStorageKey, theme);
  };

  const syncThemeButtons = () => {
    document.querySelectorAll('[data-theme-toggle]').forEach((button) => {
      const locale = button.dataset.locale === 'en' ? 'en' : 'zh';
      const currentTheme = getTheme();
      const nextTheme = currentTheme === 'dark' ? 'light' : 'dark';
      const label = button.querySelector('[data-theme-label]');

      if (label) {
        label.textContent = themeCopy[locale][currentTheme];
      }

      button.dataset.nextTheme = nextTheme;
      button.setAttribute('aria-label', themeCopy[locale].next[nextTheme]);
    });
  };

  const attachThemeButtons = () => {
    document.querySelectorAll('[data-theme-toggle]').forEach((button) => {
      if (button.dataset.bound === 'true') {
        return;
      }

      button.dataset.bound = 'true';
      button.addEventListener('click', () => {
        const nextTheme = button.dataset.nextTheme === 'light' ? 'light' : 'dark';
        applyTheme(nextTheme);
        syncThemeButtons();
      });
    });

    syncThemeButtons();
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', attachThemeButtons, { once: true });
  } else {
    attachThemeButtons();
  }
</script>
