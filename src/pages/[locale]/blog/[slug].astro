---
import { getCollection, type CollectionEntry } from 'astro:content';
import { getDictionary, getPostPath, type Locale } from '../../../lib/site';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: {
      locale: post.data.locale,
      slug: post.data.pathSlug
    },
    props: { post }
  }));
}

const { post } = Astro.props as { post: CollectionEntry<'posts'> };
const locale = post.data.locale as Locale;
const copy = getDictionary(locale);
const target = getPostPath(locale, post.data.pathSlug);
---

<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <link rel="canonical" href={target} />
    <title>{copy.post.legacyRedirect}</title>
  </head>
  <body>
    <p>{copy.post.legacyRedirect}</p>
    <p><a href={target}>{target}</a></p>
  </body>
</html>