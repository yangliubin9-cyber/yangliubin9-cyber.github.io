---
import PostCard from '../../components/PostCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPosts } from '../../lib/posts';
import { LOCALES, PROFILE, getBlogPath, getDictionary, getLanguagePaths, getLocalizedPath, type Locale } from '../../lib/site';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({
    params: { locale },
    props: { locale }
  }));
}

const { locale } = Astro.props as { locale: Locale };
const copy = getDictionary(locale);
const posts = await getPosts(locale);
const featuredPosts = posts.filter((post) => post.data.featured).slice(0, 3);
const paths = getLanguagePaths();
---

<BaseLayout
  locale={locale}
  currentNav="home"
  pagePath={getLocalizedPath(locale)}
  paths={paths}
  title={`${copy.branding.title} | ${copy.branding.subtitle}`}
  description={copy.home.heroDescription}
>
  <section class="hero panel hero--home">
    <div class="hero__copy">
      <p class="eyebrow">{copy.home.eyebrow}</p>
      <h1>{copy.branding.title}</h1>
      <p class="hero__subtitle">{copy.branding.subtitle}</p>
      <p class="hero__headline">{copy.home.heroTitle}</p>
      <p class="page-intro__description">{copy.home.heroDescription}</p>
      <div class="hero__actions">
        <a class="button" href={getBlogPath(locale)}>{copy.home.primary}</a>
        <a class="button button--ghost" href={getLocalizedPath(locale, 'about')}>{copy.home.secondary}</a>
      </div>
    </div>

    <aside class="profile-card surface">
      <img class="profile-card__avatar" src={PROFILE.avatar} alt={PROFILE.name[locale]} loading="lazy" onerror={`this.onerror=null;this.src='${PROFILE.avatarFallback}'`} />
      <div class="profile-card__content">
        <p class="eyebrow">{copy.home.introTitle}</p>
        <h2>{PROFILE.name[locale]}</h2>
        <p>{PROFILE.tagline[locale]}</p>
        <p>{copy.home.introBody}</p>
      </div>
    </aside>
  </section>

  <section class="section">
    <div class="section-heading section-heading--with-action">
      <div>
        <p class="eyebrow">{copy.home.eyebrow}</p>
        <h2>{copy.home.latestTitle}</h2>
        <p>{copy.home.latestDescription}</p>
      </div>
      <a class="text-link" href={getBlogPath(locale)}>{copy.nav.blog}</a>
    </div>

    <div class="posts-grid">
      {featuredPosts.map((post) => <PostCard post={post} locale={locale} />)}
    </div>
  </section>

  <section class="section section--split-grid">
    <article class="surface spotlight-card">
      <p class="eyebrow">SYSTEM / RATIONALE</p>
      <h2>{copy.home.spotlightTitle}</h2>
      <div class="check-list">
        {copy.home.spotlightItems.map((item) => <p>{item}</p>)}
      </div>
    </article>

    <div class="link-grid">
      <a class="surface link-card" href={getLocalizedPath(locale, 'about')}>
        <span class="pill">{copy.nav.about}</span>
        <h3>{copy.nav.about}</h3>
        <p>{copy.about.description}</p>
      </a>
      <a class="surface link-card" href={getLocalizedPath(locale, 'projects')}>
        <span class="pill">{copy.nav.projects}</span>
        <h3>{copy.nav.projects}</h3>
        <p>{copy.projects.description}</p>
      </a>
      <a class="surface link-card" href={getLocalizedPath(locale, 'uses')}>
        <span class="pill">{copy.nav.uses}</span>
        <h3>{copy.nav.uses}</h3>
        <p>{copy.uses.description}</p>
      </a>
      <a class="surface link-card" href={getLocalizedPath(locale, 'contact')}>
        <span class="pill">{copy.nav.contact}</span>
        <h3>{copy.nav.contact}</h3>
        <p>{copy.contact.description}</p>
      </a>
    </div>
  </section>
</BaseLayout>