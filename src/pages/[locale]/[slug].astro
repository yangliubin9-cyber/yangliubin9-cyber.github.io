---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import GiscusComments from '../../components/GiscusComments.astro';
import PostCard from '../../components/PostCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { findTranslation, formatDate, getAdjacentPosts, sortPosts } from '../../lib/posts';
import { getBlogPath, getDictionary, getPostPath, type Locale } from '../../lib/site';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: {
      locale: post.data.locale,
      slug: post.data.pathSlug
    },
    props: { post }
  }));
}

const { post } = Astro.props as { post: CollectionEntry<'posts'> };
const locale = post.data.locale as Locale;
const copy = getDictionary(locale);
const allPosts = await getCollection('posts');
const otherLocale = locale === 'zh' ? 'en' : 'zh';
const translation = findTranslation(allPosts, post.data.translationKey, otherLocale);
const relatedPosts = sortPosts(
  allPosts.filter((entry) => entry.data.locale === locale && entry.id !== post.id)
).slice(0, 2);
const adjacentPosts = getAdjacentPosts(allPosts, post);
const previousLabel = locale === 'zh' ? '上一篇' : 'Previous';
const nextLabel = locale === 'zh' ? '下一篇' : 'Next';
const { Content, headings } = await render(post);
const paths = {
  zh: locale === 'zh' ? getPostPath('zh', post.data.pathSlug) : getBlogPath('zh'),
  en: locale === 'en' ? getPostPath('en', post.data.pathSlug) : getBlogPath('en')
};

if (translation) {
  paths[translation.data.locale] = getPostPath(translation.data.locale, translation.data.pathSlug);
}
---

<BaseLayout
  locale={locale}
  currentNav="blog"
  pagePath={getPostPath(locale, post.data.pathSlug)}
  paths={paths}
  title={`${post.data.title} | ${copy.branding.title}`}
  description={post.data.excerpt}
>
  <article class="article-layout">
    <section class="article-hero panel">
      <a class="text-link" href={getBlogPath(locale)}>{copy.post.backToBlog}</a>
      <p class="eyebrow">{post.data.heroEyebrow ?? post.data.category}</p>
      <h1>{post.data.title}</h1>
      <p class="page-intro__description">{post.data.excerpt}</p>

      <div class="article-meta">
        <span>{copy.post.published}: {formatDate(post.data.publishedAt, locale)}</span>
        <span>{copy.post.category}: {post.data.category}</span>
        {post.data.updatedAt && <span>{copy.post.updated}: {formatDate(post.data.updatedAt, locale)}</span>}
      </div>

      <div class="tag-row tag-row--wrap">
        {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
    </section>

    <div class="article-grid">
      <div class="surface article-body">
        <Content />
      </div>

      <aside class="surface toc">
        <p class="eyebrow">{copy.post.contents}</p>
        {headings.length > 0 ? (
          <nav class="toc__nav">
            {headings.map((heading) => (
              <a href={`#${heading.slug}`} class={`toc__level toc__level--${heading.depth}`}>
                {heading.text}
              </a>
            ))}
          </nav>
        ) : (
          <p class="page-intro__description">{copy.post.noContents}</p>
        )}
      </aside>
    </div>
  </article>

  {(adjacentPosts.previous || adjacentPosts.next) && (
    <section class="surface post-pagination">
      {adjacentPosts.previous ? (
        <a class="post-pagination__link" href={getPostPath(locale, adjacentPosts.previous.data.pathSlug)}>
          <span class="eyebrow">{previousLabel}</span>
          <strong>{adjacentPosts.previous.data.title}</strong>
          <span>{adjacentPosts.previous.data.excerpt}</span>
        </a>
      ) : (
        <div class="post-pagination__spacer"></div>
      )}

      {adjacentPosts.next ? (
        <a class="post-pagination__link post-pagination__link--next" href={getPostPath(locale, adjacentPosts.next.data.pathSlug)}>
          <span class="eyebrow">{nextLabel}</span>
          <strong>{adjacentPosts.next.data.title}</strong>
          <span>{adjacentPosts.next.data.excerpt}</span>
        </a>
      ) : (
        <div class="post-pagination__spacer"></div>
      )}
    </section>
  )}

  <GiscusComments locale={locale} />

  {relatedPosts.length > 0 && (
    <section class="section">
      <div class="section-heading">
        <p class="eyebrow">BLOG / MORE</p>
        <h2>{copy.post.related}</h2>
      </div>
      <div class="posts-grid">
        {relatedPosts.map((entry) => <PostCard post={entry} locale={locale} />)}
      </div>
    </section>
  )}
</BaseLayout>
